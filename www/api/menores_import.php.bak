<?php
// menores_import.php - Importación masiva con manejo de campos vacíos
session_start();
header('Content-Type: application/json');
require_once 'config.php';

if (!isset($_SESSION['user_id']) || $_SESSION['user_role'] !== 'admin') {
    http_response_code(403);
    echo json_encode(['error' => 'No autorizado']);
    exit;
}

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    http_response_code(405);
    echo json_encode(['error' => 'Método no permitido']);
    exit;
}

if (empty($_FILES['csv']['name']) || $_FILES['csv']['error'] !== UPLOAD_ERR_OK) {
    http_response_code(400);
    echo json_encode(['error' => 'No se recibió el archivo CSV']);
    exit;
}

$ext = strtolower(pathinfo($_FILES['csv']['name'], PATHINFO_EXTENSION));
if ($ext !== 'csv') {
    http_response_code(400);
    echo json_encode(['error' => 'El archivo debe tener extensión .csv']);
    exit;
}

$pdo = getDB();

// Verificar si la tabla existe
$checkTable = $pdo->query("SHOW TABLES LIKE 'menores'");
if ($checkTable->rowCount() == 0) {
    echo json_encode(['error' => 'La tabla "menores" no existe en la base de datos']);
    exit;
}

$handle = fopen($_FILES['csv']['tmp_name'], 'r');
if (!$handle) {
    http_response_code(400);
    echo json_encode(['error' => 'No se pudo leer el archivo']);
    exit;
}

$encabezados = fgetcsv($handle);
if (!$encabezados) {
    fclose($handle);
    http_response_code(400);
    echo json_encode(['error' => 'El archivo está vacío o mal formado']);
    exit;
}

// Limpiar encabezados y eliminar BOM
$encabezados = array_map(function($h) {
    $h = trim($h);
    if (strpos($h, "\xEF\xBB\xBF") === 0) {
        $h = substr($h, 3);
    }
    return strtolower($h);
}, $encabezados);

$columnasValidas = ['tipo_doc', 'documento', 'nombre', 'apellido', 'fecha_nacimiento', 'genero', 'custodio_responsable', 'telefono_contacto', 'observaciones'];
$tiposDocValidos = ['TI', 'RC', 'CC', 'CE', 'PA', 'CN', 'PT', 'DE', 'SC', 'CD'];
$generosValidos = ['M', 'F', 'I'];

$insertados = 0;
$omitidos = 0;
$errores = [];

$stmtCheck = $pdo->prepare("SELECT id FROM menores WHERE documento = ? LIMIT 1");
$stmtInsert = $pdo->prepare("
    INSERT INTO menores (tipo_doc, documento, nombre, apellido, fecha_nacimiento, genero, custodio_responsable, telefono_contacto, observaciones, activo)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 1)
");

$fila_num = 1;
while (($fila = fgetcsv($handle)) !== false) {
    $fila_num++;
    
    // Saltar filas completamente vacías
    if (count(array_filter($fila, fn($v) => trim((string)$v) !== '')) === 0) {
        continue;
    }
    
    // Asegurar que la fila tenga al menos tantos elementos como encabezados
    while (count($fila) < count($encabezados)) {
        $fila[] = '';
    }
    
    $datos = array_combine(
        array_slice($encabezados, 0, count($fila)),
        array_map('trim', $fila)
    );

    $documento = $datos['documento'] ?? '';
    $nombre = $datos['nombre'] ?? '';

    if (empty($documento) || empty($nombre)) {
        $omitidos++;
        $errores[] = "Fila $fila_num: documento o nombre vacío";
        continue;
    }

    // Verificar si ya existe
    $stmtCheck->execute([$documento]);
    if ($stmtCheck->fetch()) {
        $omitidos++;
        $errores[] = "Fila $fila_num: documento $documento ya existe";
        continue;
    }

    $tipoDoc = strtoupper($datos['tipo_doc'] ?? 'TI');
    if (!in_array($tipoDoc, $tiposDocValidos, true)) {
        $tipoDoc = 'TI';
    }
    
    $genero = strtoupper($datos['genero'] ?? 'I');
    if (!in_array($genero, $generosValidos, true)) {
        $genero = 'I';
    }
    
    // FECHA: convertir vacío a NULL
    $fechaNacimiento = null;
    if (!empty($datos['fecha_nacimiento'])) {
        $fechaNacimiento = $datos['fecha_nacimiento'];
        // Validar formato YYYY-MM-DD
        if (!preg_match('/^\d{4}-\d{2}-\d{2}$/', $fechaNacimiento)) {
            $omitidos++;
            $errores[] = "Fila $fila_num: fecha '$fechaNacimiento' no es YYYY-MM-DD";
            continue;
        }
    }
    
    // Campos opcionales: convertir vacíos a NULL
    $custodio = !empty($datos['custodio_responsable']) ? $datos['custodio_responsable'] : null;
    $telefono = !empty($datos['telefono_contacto']) ? $datos['telefono_contacto'] : null;
    $observaciones = !empty($datos['observaciones']) ? $datos['observaciones'] : null;

    try {
        $stmtInsert->execute([
            $tipoDoc,
            $documento,
            $nombre,
            $datos['apellido'] ?? '',
            $fechaNacimiento,
            $genero,
            $custodio,
            $telefono,
            $observaciones
        ]);
        $insertados++;
    } catch (PDOException $e) {
        $omitidos++;
        $errores[] = "Fila $fila_num: error BD - " . $e->getMessage();
    }
}

fclose($handle);

echo json_encode([
    'success' => true,
    'insertados' => $insertados,
    'omitidos' => $omitidos,
    'errores' => $errores
]);
