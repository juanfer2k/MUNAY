.badge-completed { background:#1E8449; color:#fff; }
.badge-cancelled { background:#e74c3c; color:#fff; }
.ficha-footer { margin-top:30px; padding-top:20px; border-top:2px solid #f0f0f0; text-align:center; font-size:13px; color:#95a5a6; }
.ficha-footer .qr-hint { display:inline-block; background:#f8f9fa; padding:8px 16px; border-radius:20px; font-size:12px; color:#5d6d7e; }
